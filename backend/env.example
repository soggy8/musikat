# Metadata catalog (user can also switch in the web UI)
# Default: deezer (free, no API key) or spotify (requires credentials below)
DEFAULT_METADATA_PROVIDER=deezer

# Spotify (optional — only if you use catalog "spotify")
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8000/callback

# Navidrome Configuration
# Single library (default when NAVIDROME_MUSIC_PATHS is unset; Docker often uses /music)
NAVIDROME_MUSIC_PATH=/path/to/navidrome/music
# Optional: multiple comma- or newline-separated absolute paths — each appears as "Download to" in the UI
# NAVIDROME_MUSIC_PATHS=/data/music/a,/data/music/b
# NAVIDROME_MUSIC_LABELS=Library A,Library B
# Optional: Navidrome API URL for triggering scans (requires admin credentials)
NAVIDROME_API_URL=http://localhost:4533
NAVIDROME_USERNAME=admin
NAVIDROME_PASSWORD=password
# Periodically scan NAVIDROME_MUSIC_PATH and mark matching catalog tracks as downloaded (SQLite)
# NAVIDROME_SYNC_ENABLED=true
# NAVIDROME_SYNC_INTERVAL_HOURS=4
# NAVIDROME_SYNC_INITIAL_DELAY_SEC=120
# NAVIDROME_SYNC_API_DELAY_SEC=0.12

# Download Configuration
# For testing: download to local folder. Later, remove this and download directly to Navidrome
DOWNLOAD_DIR=./downloads
OUTPUT_FORMAT=mp3
AUDIO_QUALITY=128
# Delay before deleting browser temp files (seconds); avoids 404 on duplicate GETs
# TEMP_FILE_CLEANUP_DELAY_SEC=60

# YouTube Configuration
# Optional: Path to YouTube cookies file (Netscape format) for bypassing bot detection
# Export cookies using browser extension or yt-dlp --cookies-from-browser
# See: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# YOUTUBE_COOKIES_PATH=/path/to/youtube_cookies.txt

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

